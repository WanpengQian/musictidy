---
import "../styles/global.css";
import {
  LOCALES,
  LOCALE_LABELS,
  LOCALE_LANG_TAG,
  LOCALE_FONT,
  pathFor,
  t,
  type Locale,
} from "../lib/i18n";

interface Props {
  title?: string;
  description?: string;
}
const locale = (Astro.currentLocale || "zh") as Locale;
const tr = (k: string) => t(locale, k);
const langTag = LOCALE_LANG_TAG[locale];
const font = LOCALE_FONT[locale];

const titleSuffix = tr("meta.titleSuffix");
const defaultDesc = tr("meta.description");
const { title = "MusicTidy", description = defaultDesc } = Astro.props;
const fullTitle = title === "MusicTidy" ? titleSuffix : `${title} · MusicTidy`;

const currentPath = new URL(Astro.url).pathname;
---
<!doctype html>
<html lang={langTag} style={`--app-font: ${font};`}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0d0a1f" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={Astro.url.href} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <title>{fullTitle}</title>
  <style is:global>
    html { font-family: var(--app-font); }
  </style>
</head>
<body>
  <header class="nav">
    <div class="container nav-row">
      <a class="brand" href={pathFor(locale, "/")}>
        <img src="/favicon.svg" alt="" />
        MusicTidy
      </a>
      <nav class="nav-links">
        <!-- 文档页（features/deploy/support/privacy）暂时只有 zh 版，所有 locale 都指 zh root -->
        <a href="/features">{tr("nav.features")}</a>
        <a href="/deploy">{tr("nav.deploy")}</a>
        <a href="/support">{tr("nav.support")}</a>
        <a href="/privacy">{tr("nav.privacy")}</a>
        <a href="https://app.musictidy.com" target="_blank" rel="noopener">{tr("nav.tryWeb")} ↗</a>
        <a href="https://github.com/WanpengQian/musictidy" target="_blank" rel="noopener">{tr("nav.github")}</a>
        <select
          class="lang"
          onchange="location.href = this.value"
          aria-label="Language"
        >
          {/* 切换语言只在 home 之间跳，文档没翻译先回 home */}
          {LOCALES.map((l) => (
            <option
              value={pathFor(l, "/")}
              selected={l === locale}
            >
              {LOCALE_LABELS[l]}
            </option>
          ))}
        </select>
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer class="footer">
    <div class="container footer-row">
      <div>{tr("footer.tagline")}</div>
      <div class="footer-links">
        <a href={pathFor(locale, "/privacy")}>{tr("footer.privacy")}</a>
        <a href={pathFor(locale, "/support")}>{tr("footer.support")}</a>
        <a href="https://app.musictidy.com" target="_blank" rel="noopener">app.musictidy.com</a>
        <a href="https://github.com/WanpengQian/musictidy" target="_blank" rel="noopener">{tr("footer.github")}</a>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
  .lang {
    margin-left: 4px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.18);
    color: inherit;
    border-radius: 6px;
    padding: 4px 8px;
    font-size: 12px;
    font-family: inherit;
    cursor: pointer;
  }
  .lang:hover { border-color: rgba(255,255,255,0.32); }
  .lang option { color: #111; }
</style>
