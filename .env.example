# ════════════════════════════════════════════════════
# 必填：复制为 .env，改这两行就能起服务
# ════════════════════════════════════════════════════

# 你音乐库的根目录（服务以只读方式访问）
MUSIC_ROOT=/zdata/music

# 监听端口（nginx 反代到这个端口）
BIND_PORT=8000


# ════════════════════════════════════════════════════
# 以下都有合理默认值，没特别需求不用动
# ════════════════════════════════════════════════════

# 数据存哪儿（SQLite + 转码缓存 + .trash）
# FreeBSD 习惯放 /var/db；macOS dev 可以放 ./data
DATA_DIR=/var/db/musictidy

BIND_HOST=127.0.0.1

# MusicBrainz 要求 UA 带联系方式（不填会被 rate-limit 严格对待）
# 改成你自己的 contact email 再上线
MB_USER_AGENT=MusicTidy/0.1 ( you@example.com )

# AcoustID 免费 API key —— 不填的话 fingerprint 识别会跳过
# 注册一个 5 秒：https://acoustid.org/new-application
ACOUSTID_API_KEY=

# 转码
DEFAULT_CODEC_WIFI=flac
DEFAULT_CODEC_CELLULAR=aac
DEFAULT_AAC_BITRATE=256
TRANSCODE_CACHE_GB=10
FFMPEG_CONCURRENCY=2

# 任务队列 worker 数
# 树莓派 / 老 NAS: 3
# 普通 NAS / Intel NUC: 5-8
# M 系 Mac mini / 强力服务器: 15-20
QUEUE_WORKERS=5
QUEUE_FINGERPRINT_CONCURRENCY=3   # AcoustID 限制 3 req/sec
QUEUE_MB_ARTIST_CONCURRENCY=1     # MusicBrainz 限制 1 req/sec

# 软删
TRASH_RETENTION_DAYS=30
UNDO_WINDOW_SEC=5

# 安全闸：第一版禁止改/移用户文件，只允许 trash
# 等你信任流程了再设为 true
ALLOW_FILE_WRITES=false

# 登录密码
# 留空 = 跳过 auth（dev 默认；生产必填）
# 设了之后所有 API + 网页都需要 token；除 /login /static /healthz /docs
APP_PASSWORD=
# 公网 + HTTPS 后改 true（cookie 只走 https）
COOKIE_SECURE=false
SESSION_TTL_DAYS=30
